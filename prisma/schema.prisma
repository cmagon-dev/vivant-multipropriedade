generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// ===== MULTI-TENANT (opcional) =====
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoleAssignments UserRoleAssignment[]
  userPermissions UserPermission[]
  capitalFunds CapitalFund[]
  capitalAssetConfigs CapitalAssetConfig[]
  capitalInvestorProfiles CapitalInvestorProfile[]
  capitalParticipations CapitalParticipation[]
  capitalDistributions CapitalDistribution[]
  capitalDistributionItems CapitalDistributionItem[]
  capitalValuations CapitalValuation[]
  capitalLiquidityRequests CapitalLiquidityRequest[]
  capitalPayments CapitalPayment[]
  capitalWallets CapitalWallet[]
  capitalTransactions CapitalTransaction[]
  capitalComplianceDocuments CapitalComplianceDocument[]
  capitalSettings CapitalSettings[]

  @@map("companies")
}

// ===== AUTENTICAÇÃO =====

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          UserRole  @default(EDITOR)
  active        Boolean   @default(true)
  defaultRoute  String?   // rota padrão pós-login (ex: /admin, /admin-portal, /dashboard)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  destinations  Destination[]
  auditLogs     AuditLog[]
  userRoleAssignments UserRoleAssignment[]
  userPermissions UserPermission[]
  tutorialProgress UserTutorialProgress[]
  leadsOwned    Lead[]
  leadActivities LeadActivity[]
  leadTypeAssignmentsAsDefault LeadTypeAssignment[]
  systemTasksAssigned          SystemTask[]
  systemEvents                SystemEvent[]
  capitalInvestorProfiles      CapitalInvestorProfile[]
  captacoesResponsavel         ImovelCaptacao[]        @relation("CaptacaoResponsavel")
  captacoesCriadas             ImovelCaptacao[]        @relation("CaptacaoCriador")

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

// ===== RBAC (Roles & Permissions) =====
model Role {
  id          String   @id @default(cuid())
  key         String   @unique  // SUPER_ADMIN, ADMIN, STAFF, COTISTA
  name        String
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoleAssignments UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique  // users.manage, roles.manage, etc.
  name        String
  description String?  @db.Text
  group       String   // agrupamento: admin, dashboard, cotista, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions  RolePermission[]
  userPermissions  UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  companyId String?  // null = global
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([roleId])
  @@index([companyId])
  @@map("user_roles")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  companyId    String?    // null = global (override)
  granted      Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, companyId])
  @@index([permissionId])
  @@index([companyId])
  @@map("user_permissions")
}

// ===== TUTORIAL (progresso por módulo) =====
model UserTutorialProgress {
  id          String    @id @default(cuid())
  userId      String
  key         String    // ex: dashboard, admin, cotista
  completedAt DateTime?
  dismissedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_tutorial_progress")
}

// ===== AJUDA CONTEXTUAL (HelpTip) =====
model HelpContent {
  id           String   @id @default(cuid())
  key          String   @unique  // ex: properties.name, users.email
  title        String
  description  String?  @db.Text
  shortText    String?  @db.Text
  videoUrl     String?
  audienceRole String?  // null = todos; ou SUPER_ADMIN, ADMIN, etc.
  updatedAt    DateTime @updatedAt

  @@index([key])
  @@map("help_contents")
}

// ===== TELEMETRIA DONO (eventos + pendências) =====
enum SystemEventSeverity {
  INFO
  WARN
  CRITICAL
}

enum SystemEventStatus {
  OK
  PENDING
  FAILED
}

model SystemEvent {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now())
  actorUserId   String?
  actorUser     User?               @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole     String?
  type          String
  entityType    String?
  entityId      String?
  productKey    String?
  severity      SystemEventSeverity  @default(INFO)
  status        SystemEventStatus    @default(OK)
  message       String              @db.Text
  meta          Json?

  @@index([createdAt])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([actorUserId])
  @@map("system_events")
}

enum SystemTaskStatus {
  OPEN
  DONE
  CANCELED
}

enum SystemTaskPriority {
  LOW
  MED
  HIGH
}

model SystemTask {
  id                String            @id @default(cuid())
  createdAt         DateTime          @default(now())
  dueAt             DateTime?
  status            SystemTaskStatus   @default(OPEN)
  title             String
  description       String?           @db.Text
  assignedToUserId  String?
  assignedTo        User?             @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  relatedEntityType String?
  relatedEntityId   String?
  productKey        String?
  priority          SystemTaskPriority @default(MED)
  meta              Json?
  createdByUserId   String?
  source            String?

  @@index([status])
  @@index([dueAt])
  @@index([assignedToUserId])
  @@map("system_tasks")
}

// ===== CRM — Motor de Funil Configurável =====
model LeadType {
  id              String    @id @default(cuid())
  key             String    @unique
  name            String
  description     String?   @db.Text
  isActive        Boolean   @default(true)
  order           Int       @default(0)
  initialStageId  String?
  initialStage    LeadStage? @relation("InitialStage", fields: [initialStageId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stages LeadStage[]
  leads  Lead[]
  lossReasons LeadLossReason[]
  assignment LeadTypeAssignment?

  @@map("lead_types")
}

model LeadTypeAssignment {
  id                 String   @id @default(cuid())
  leadTypeId         String   @unique
  leadType           LeadType @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  defaultOwnerUserId String
  defaultOwner       User     @relation(fields: [defaultOwnerUserId], references: [id], onDelete: Restrict)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([leadTypeId])
  @@index([defaultOwnerUserId])
  @@map("lead_type_assignments")
}

model LeadLossReason {
  id         String   @id @default(cuid())
  leadTypeId String
  leadType   LeadType @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  leads Lead[]

  @@unique([leadTypeId, order])
  @@index([leadTypeId])
  @@map("lead_loss_reasons")
}

model LeadStage {
  id                String    @id @default(cuid())
  leadTypeId        String
  leadType          LeadType  @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  name              String
  order             Int
  isFinal           Boolean   @default(false)
  finalStatus       LeadFinalStatus?
  slaEnabled        Boolean   @default(true)
  slaHours          Int?
  slaThresholds    Json?     // [{ color: "YELLOW", hoursLeft: 12 }, { color: "ORANGE", hoursLeft: 3 }] ordenado menor primeiro
  isActive          Boolean   @default(true)
  whatsTemplate     String?   @db.Text
  playbookChecklist Json?     // array de strings
  nextActionType    String?   // CALL | WHATSAPP | PROPOSAL | VISIT | NOTE
  helpText          String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  leads Lead[]
  typesUsingAsInitial LeadType[] @relation("InitialStage")
  slaEvents LeadSlaEvent[]

  @@unique([leadTypeId, order])
  @@index([leadTypeId])
  @@map("lead_stages")
}

enum LeadFinalStatus {
  WON
  LOST
}

model Lead {
  id               String        @id @default(cuid())
  leadTypeId       String
  leadType         LeadType      @relation(fields: [leadTypeId], references: [id], onDelete: Restrict)
  stageId          String
  stage            LeadStage     @relation(fields: [stageId], references: [id], onDelete: Restrict)
  ownerUserId      String?
  owner            User?         @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  name             String
  phone            String
  email            String
  city             String?       // captação pública
  source           String?
  origin           String?       // Como conheceu: Google, Instagram, Indicação, etc.
  notes            String?       @db.Text
  status           LeadStatus    @default(ACTIVE)
  lossReasonId     String?
  lossReason       LeadLossReason? @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)
  stageEnteredAt   DateTime?
  stageDueAt       DateTime?
  stageBreachedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  activities LeadActivity[]
  slaEvents  LeadSlaEvent[]

  @@index([leadTypeId])
  @@index([stageId])
  @@index([ownerUserId])
  @@index([status])
  @@index([lossReasonId])
  @@index([stageDueAt])
  @@index([ownerUserId, stageDueAt])
  @@map("leads")
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
}

model LeadActivity {
  id          String        @id @default(cuid())
  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorUserId String
  actor       User          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  type        LeadActivityType
  message     String?       @db.Text
  meta        Json?
  createdAt   DateTime      @default(now())

  @@index([leadId])
  @@index([actorUserId])
  @@map("lead_activities")
}

enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  VISIT
  PROPOSAL
  STATUS_CHANGE
}

enum LeadSlaEventType {
  STAGE_CHANGED
  SLA_WARNING
  SLA_BREACHED
  SLA_RESOLVED
}

model LeadSlaEvent {
  id        String           @id @default(cuid())
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stageId   String
  stage     LeadStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  type      LeadSlaEventType
  meta      Json?
  createdAt DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([createdAt])
  @@map("lead_sla_events")
}

// ===== CONTEÚDO =====

model Property {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String          @default("") @db.Text
  location        String
  cidade          String
  destinoId       String
  destino         Destination     @relation(fields: [destinoId], references: [id], onDelete: Restrict)
  condominio      String
  type            String
  priceValue      Int
  bedrooms        Int
  bathrooms       Int
  area            Int
  maxGuests       Int?
  fraction        String
  price           String
  monthlyFee      String
  weeks           String
  totalCotas      Int?
  images          Json
  features        Json
  appreciation    String
  status          PropertyStatus  @default(DISPONIVEL)
  highlight       Boolean         @default(false)
  published       Boolean         @default(false)
  publishedAt     DateTime?
  
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relações com portal do cotista
  cotas           CotaPropriedade[]
  assembleias     Assembleia[]
  mensagens       Mensagem[]
  documentos      Documento[]
  calendarYears   PropertyCalendarYear[]
  weekExchangeRequests WeekExchangeRequest[]
  weekMarketplaceListings WeekMarketplaceListing[]
  notificacoes    Notificacao[]
  // Vivant Capital: camada de investimento sobre o imóvel (sem duplicar dados)
  capitalAssetConfigs CapitalAssetConfig[]
  // Imobilizado da casa (gestão admin, visualização cotista)
  assets          PropertyAsset[]
  checkinReports  CheckinCheckoutReport[]
  checkoutOccurrences CheckoutOccurrence[]

  @@index([destinoId])
  @@index([published])
  @@index([slug])
  @@map("properties")
}

enum PropertyStatus {
  DISPONIVEL
  ULTIMAS_COTAS
  PRE_LANCAMENTO
  VENDIDO
}

model Destination {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  state           String
  emoji           String
  color           String
  subtitle        String
  location        String
  description     String   @db.Text
  climate         String   @db.Text
  lifestyle       String   @db.Text
  features        Json
  images          Json     @default("[]")
  appreciation    String
  published       Boolean  @default(false)
  publishedAt     DateTime?
  order           Int      @default(0)
  
  properties      Property[]
  targetedMensagens Mensagem[]          @relation("MensagemTargetDestino")
  imovelCaptacoes ImovelCaptacao[]
  
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([published])
  @@index([slug])
  @@index([order])
  @@map("destinations")
}

// ===== AUDITORIA =====

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===== COTISTAS E MULTIPROPRIEDADE =====

model Cotista {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  cpf               String              @unique
  phone             String?
  password          String
  avatar            String?
  active            Boolean             @default(true)
  emailVerified     DateTime?
  
  inviteToken       String?             @unique
  inviteTokenExpiry DateTime?
  invitedBy         String?
  invitedAt         DateTime?
  
  cotas             CotaPropriedade[]
  weekReservations  WeekReservation[]
  weekExchangeRequests WeekExchangeRequest[]
  weekPeerInterests WeekExchangePeerInterest[]
  weekMarketplaceListings WeekMarketplaceListing[]
  weekMarketplaceProposals WeekMarketplaceProposal[]
  votosAssembleia   VotoAssembleia[]
  mensagens         Mensagem[]
  targetedMensagens Mensagem[]           @relation("MensagemTargetCotista")
  notificacoes      Notificacao[]
  checkinReports    CheckinCheckoutReport[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([email])
  @@index([cpf])
  @@index([inviteToken])
  @@map("cotistas")
}

model CotaPropriedade {
  id                String          @id @default(cuid())
  cotistaId         String
  cotista           Cotista         @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  propertyId        String
  property          Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  
  numeroCota        String
  percentualCota    Decimal         @db.Decimal(5,2)
  semanasAno        Int             @default(8)
  
  ativo             Boolean         @default(true)
  dataAquisicao     DateTime        @default(now())
  
  cobrancas         Cobranca[]
  weekReservations  WeekReservation[]
  weekAssignments   PropertyWeekAssignment[]
  weekExchangeRequests WeekExchangeRequest[]
  marketplaceListingAsOwner WeekMarketplaceListing[] @relation("ListingOwnerCota")
  marketplaceProposalsAsProposer WeekMarketplaceProposal[] @relation("ProposerCota")
  usageOverridesFrom WeekUsageOverride[] @relation("UsageFromCota")
  usageOverridesTo   WeekUsageOverride[] @relation("UsageToCota")
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@unique([cotistaId, propertyId, numeroCota])
  @@index([cotistaId])
  @@index([propertyId])
  @@map("cotas_propriedade")
}

// ===== CALENDÁRIO E RESERVAS (semanas oficiais) =====

enum PropertyAssetCategory {
  MOVEIS
  ELETRODOMESTICOS
  ELETRONICOS
  UTENSILIOS
  DECORACAO
  CAMA_MESA_BANHO
  AREA_EXTERNA
  OUTROS
}

enum CheckoutOccurrenceType {
  QUEBRADO
  DANIFICADO
  AUSENTE
  PRECISA_MANUTENCAO
  MAU_FUNCIONAMENTO
  OUTRO
}

model PropertyAsset {
  id         String               @id @default(cuid())
  propertyId String
  property   Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  category   PropertyAssetCategory @default(OUTROS)
  unitValue  Decimal              @db.Decimal(12,2)
  quantity   Int                  @default(1)
  totalValue Decimal              @db.Decimal(12,2)
  notes      String?              @db.Text
  active     Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  occurrences CheckoutOccurrence[]

  @@index([propertyId])
  @@index([category])
  @@map("property_assets")
}

model CheckinCheckoutReport {
  id                  String    @id @default(cuid())
  propertyId          String
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  cotistaId           String
  cotista             Cotista   @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  weekReservationId   String?
  weekReservation     WeekReservation?  @relation(fields: [weekReservationId], references: [id], onDelete: SetNull)
  expectedCheckinDate DateTime?
  expectedCheckinTime String?
  expectedCheckoutDate DateTime?
  expectedCheckoutTime String?
  hadBrokenItem       Boolean   @default(false)
  hadMaintenance      Boolean   @default(false)
  description         String?   @db.Text
  observations        String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  occurrences         CheckoutOccurrence[]

  @@index([propertyId])
  @@index([cotistaId])
  @@index([weekReservationId])
  @@map("checkin_checkout_reports")
}

model CheckoutOccurrence {
  id             String                @id @default(cuid())
  reportId       String
  report         CheckinCheckoutReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assetId        String?
  asset          PropertyAsset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  category       PropertyAssetCategory @default(OUTROS)
  occurrenceType CheckoutOccurrenceType
  description    String                @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([reportId])
  @@index([propertyId])
  @@index([assetId])
  @@map("checkout_occurrences")
}

enum StatusReserva {
  PENDENTE
  CONFIRMADA
  NAO_UTILIZADA
  EM_USO
  FINALIZADA
  CANCELADA
  DISPONIVEL_TROCA
}

// ===== FINANCEIRO =====

model Cobranca {
  id                String              @id @default(cuid())
  cotaId            String
  cota              CotaPropriedade     @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  
  tipo              TipoCobranca
  descricao         String
  
  valor             Decimal             @db.Decimal(10,2)
  valorPago         Decimal             @default(0) @db.Decimal(10,2)
  
  mesReferencia     Int
  anoReferencia     Int
  
  dataVencimento    DateTime
  dataPagamento     DateTime?
  
  status            StatusCobranca      @default(PENDENTE)
  
  urlBoleto         String?
  urlComprovante    String?
  
  observacoes       String?             @db.Text
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([cotaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([anoReferencia, mesReferencia])
  @@map("cobrancas")
}

enum TipoCobranca {
  CONDOMINIO
  LIMPEZA
  MANUTENCAO
  SEGURO
  IPTU
  TAXA_GESTAO
  OUTROS
}

enum StatusCobranca {
  PENDENTE
  VENCIDA
  PAGA
  PAGA_PARCIAL
  CANCELADA
}

// ===== ASSEMBLEIAS E VOTAÇÕES =====

model Assembleia {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String              @db.Text
  tipo              TipoAssembleia
  
  dataRealizacao    DateTime
  dataInicio        DateTime
  dataFim           DateTime
  
  status            StatusAssembleia    @default(AGENDADA)
  
  quorumMinimo      Decimal             @db.Decimal(5,2)
  quorumAlcancado   Decimal?            @db.Decimal(5,2)
  
  ataUrl            String?
  documentosUrls    Json?
  
  pautas            PautaAssembleia[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([status])
  @@index([dataRealizacao])
  @@map("assembleias")
}

enum TipoAssembleia {
  ORDINARIA
  EXTRAORDINARIA
  VIRTUAL
}

enum StatusAssembleia {
  AGENDADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

model PautaAssembleia {
  id                String              @id @default(cuid())
  assembleiaId      String
  assembleia        Assembleia          @relation(fields: [assembleiaId], references: [id], onDelete: Cascade)
  
  ordem             Int
  titulo            String
  descricao         String              @db.Text
  tipo              TipoPauta
  
  requererVotacao   Boolean             @default(false)
  votacaoAberta     Boolean             @default(false)
  
  votos             VotoAssembleia[]
  
  aprovada          Boolean?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([assembleiaId])
  @@map("pautas_assembleia")
}

enum TipoPauta {
  INFORMATIVA
  DELIBERATIVA
  ELETIVA
}

model VotoAssembleia {
  id                String              @id @default(cuid())
  pautaId           String
  pauta             PautaAssembleia     @relation(fields: [pautaId], references: [id], onDelete: Cascade)
  cotistaId         String
  cotista           Cotista             @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  
  voto              TipoVoto
  justificativa     String?             @db.Text
  
  votadoEm          DateTime            @default(now())
  
  @@unique([pautaId, cotistaId])
  @@index([pautaId])
  @@index([cotistaId])
  @@map("votos_assembleia")
}

enum TipoVoto {
  FAVOR
  CONTRA
  ABSTENCAO
}

// ===== COMUNICAÇÃO E DOCUMENTOS =====

model Mensagem {
  id                String              @id @default(cuid())
  propertyId        String?
  property          Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  targetType        MensagemTargetType  @default(CASA)
  targetCotistaId   String?
  targetCotista     Cotista?            @relation("MensagemTargetCotista", fields: [targetCotistaId], references: [id], onDelete: SetNull)
  targetCondominio  String?
  targetDestinoId   String?
  targetDestino     Destination?        @relation("MensagemTargetDestino", fields: [targetDestinoId], references: [id], onDelete: SetNull)
  
  autorId           String?
  autor             Cotista?            @relation(fields: [autorId], references: [id], onDelete: SetNull)
  autorNome         String
  autorTipo         TipoAutor           @default(ADMINISTRACAO)
  
  titulo            String
  conteudo          String              @db.Text
  tipo              TipoMensagem        @default(AVISO)
  prioridade        PrioridadeMensagem  @default(NORMAL)
  
  anexosUrls        Json?
  
  fixada            Boolean             @default(false)
  ativa             Boolean             @default(true)
  
  visualizacoes     VisualizacaoMensagem[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@index([createdAt])
  @@map("mensagens")
}

enum TipoAutor {
  ADMINISTRACAO
  COTISTA
  SISTEMA
}

enum TipoMensagem {
  AVISO
  COMUNICADO
  URGENTE
  MANUTENCAO
  EVENTO
  LEMBRETE
}

enum MensagemTargetType {
  CASA
  COTISTA
  CONDOMINIO
  DESTINO
}

enum PrioridadeMensagem {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

model VisualizacaoMensagem {
  id                String          @id @default(cuid())
  mensagemId        String
  mensagem          Mensagem        @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  cotistaId         String
  
  visualizadoEm     DateTime        @default(now())
  
  @@unique([mensagemId, cotistaId])
  @@index([mensagemId])
  @@map("visualizacoes_mensagem")
}

model Documento {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String?             @db.Text
  tipo              TipoDocumento
  categoria         String?
  
  url               String
  nomeArquivo       String
  tamanhoBytes      Int
  mimeType          String
  
  versao            String              @default("1.0")
  ativo             Boolean             @default(true)
  
  uploadedBy        String?
  uploadedAt        DateTime            @default(now())
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@map("documentos")
}

enum TipoDocumento {
  ESTATUTO
  REGIMENTO_INTERNO
  ATA
  CONTRATO
  MANUAL
  PLANTA
  LAUDO
  OUTROS
}

// ===== NOTIFICAÇÕES =====

model Notificacao {
  id           String   @id @default(cuid())
  cotistaId    String
  cotista      Cotista  @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  /// Escopo da casa (oportunidades / trocas): filtro e auditoria; não substitui destino por cotista.
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tipo         String
  titulo       String
  mensagem     String   @db.Text
  lida         Boolean  @default(false)
  url          String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  
  @@index([cotistaId])
  @@index([propertyId])
  @@index([lida])
  @@index([createdAt])
  @@map("notificacoes")
}

// ===== CALENDÁRIO OFICIAL + DISTRIBUIÇÃO + RESERVAS + TROCAS MEDIADAS =====

enum WeekTier {
  GOLD
  SILVER
  BLACK
}

enum OfficialWeekType {
  TYPE_1
  TYPE_2
  TYPE_3
  TYPE_4
  TYPE_5
  TYPE_6
  EXTRA
}

enum CalendarYearStatus {
  DRAFT
  PUBLISHED
}

/// Um ano civil de calendário oficial por propriedade.
model PropertyCalendarYear {
  id         String             @id @default(cuid())
  propertyId String
  property   Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  year       Int
  label      String?
  status     CalendarYearStatus @default(DRAFT)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  weeks             PropertyCalendarWeek[]
  distributionSlots CalendarDistributionSlot[]
  weekMarketplaceListings WeekMarketplaceListing[]

  @@unique([propertyId, year])
  @@index([propertyId])
  @@map("property_calendar_years")
}

/// Semana oficial (datas reais + tipo + classificação).
model PropertyCalendarWeek {
  id                     String               @id @default(cuid())
  propertyCalendarYearId String
  calendarYear           PropertyCalendarYear @relation(fields: [propertyCalendarYearId], references: [id], onDelete: Cascade)
  weekIndex              Int
  startDate              DateTime
  endDate                DateTime
  description            String?
  officialWeekType       OfficialWeekType
  tier                   WeekTier
  isExtra                Boolean              @default(false)
  exchangeAllowed        Boolean              @default(true)
  isBlocked              Boolean              @default(false)
  weight                 Decimal              @default(1) @db.Decimal(12, 4)
  notes                  String?              @db.Text
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  assignments       PropertyWeekAssignment[]
  weekReservations    WeekReservation[]
  requestsAsOwned     WeekExchangeRequest[]    @relation("OwnedCalendarWeek")
  requestsAsDesired   WeekExchangeRequest[]    @relation("DesiredCalendarWeek")
  peerOffers          WeekExchangePeerInterest[] @relation("OfferedCalendarWeek")
  marketplaceListings WeekMarketplaceListing[]
  marketplaceProposerWeeks WeekMarketplaceProposal[] @relation("ProposerWeek")

  usageOverrides      WeekUsageOverride[]

  @@unique([propertyCalendarYearId, weekIndex])
  @@index([propertyCalendarYearId])
  @@index([startDate, endDate])
  @@map("property_calendar_weeks")
}

/// Rodada de distribuição de semanas às cotas (por ano).
model CalendarDistributionSlot {
  id                     String               @id @default(cuid())
  propertyCalendarYearId String
  calendarYear           PropertyCalendarYear @relation(fields: [propertyCalendarYearId], references: [id], onDelete: Cascade)
  label                  String
  status                 String               @default("RASCUNHO")
  notes                  String?              @db.Text
  finalizedAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  assignments PropertyWeekAssignment[]

  @@index([propertyCalendarYearId])
  @@map("calendar_distribution_slots")
}

model PropertyWeekAssignment {
  id                     String               @id @default(cuid())
  distributionSlotId     String
  distributionSlot       CalendarDistributionSlot @relation(fields: [distributionSlotId], references: [id], onDelete: Cascade)
  cotaId                 String
  cota                   CotaPropriedade      @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  propertyCalendarWeekId String
  calendarWeek           PropertyCalendarWeek @relation(fields: [propertyCalendarWeekId], references: [id], onDelete: Cascade)
  locked                 Boolean              @default(false)
  notes                  String?              @db.Text
  createdAt              DateTime             @default(now())

  @@unique([distributionSlotId, propertyCalendarWeekId])
  @@index([cotaId])
  @@index([propertyCalendarWeekId])
  @@map("property_week_assignments")
}

model WeekReservation {
  id                     String               @id @default(cuid())
  cotaId                 String
  cota                   CotaPropriedade      @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  cotistaId              String
  cotista                Cotista              @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  propertyCalendarWeekId String
  calendarWeek           PropertyCalendarWeek @relation(fields: [propertyCalendarWeekId], references: [id], onDelete: Cascade)

  status            StatusReserva @default(PENDENTE)
  confirmadoEm      DateTime?
  checkInEm         DateTime?
  checkOutEm        DateTime?
  limpezaSolicitada Boolean       @default(false)
  limpezaRealizada  Boolean       @default(false)
  observacoes       String?       @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  checkinReports CheckinCheckoutReport[]

  @@unique([cotaId, propertyCalendarWeekId])
  @@index([cotistaId])
  @@index([status])
  @@index([propertyCalendarWeekId])
  @@map("week_reservations")
}

enum WeekExchangeRequestStatus {
  REQUESTED
  UNDER_ADMIN_REVIEW
  ADMIN_OPTION_FOUND
  PUBLISHED_TO_PEERS
  PEER_INTEREST_FOUND
  NEGOTIATION_IN_PROGRESS
  PENDING_ADMIN_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

/// Solicitação de troca — semanas oficiais; admin no fluxo.
model WeekExchangeRequest {
  id                    String   @id @default(cuid())
  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  cotistaId             String
  cotista               Cotista @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  cotaId                String
  cota                  CotaPropriedade @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  ownedCalendarWeekId   String
  ownedWeek             PropertyCalendarWeek @relation("OwnedCalendarWeek", fields: [ownedCalendarWeekId], references: [id], onDelete: Restrict)
  desiredCalendarWeekId String?
  desiredWeek           PropertyCalendarWeek? @relation("DesiredCalendarWeek", fields: [desiredCalendarWeekId], references: [id], onDelete: SetNull)
  desiredPeriodStart    DateTime?
  desiredPeriodEnd      DateTime?
  acceptsAlternatives   Boolean  @default(false)
  publicToPeers         Boolean  @default(false)
  status                  WeekExchangeRequestStatus @default(REQUESTED)
  expiresAt               DateTime?
  notes                   String?  @db.Text
  adminNotes              String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  peerInterests WeekExchangePeerInterest[]
  eventLogs     WeekExchangeEventLog[]

  @@index([propertyId])
  @@index([cotistaId])
  @@index([status])
  @@map("week_exchange_requests")
}

enum WeekPeerInterestStatus {
  PENDING
  WITHDRAWN
  APPROVED
  REJECTED
}

model WeekExchangePeerInterest {
  id                    String   @id @default(cuid())
  requestId             String
  request               WeekExchangeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  interestedCotistaId   String
  interestedCotista     Cotista @relation(fields: [interestedCotistaId], references: [id], onDelete: Cascade)
  offeredCalendarWeekId String
  offeredWeek           PropertyCalendarWeek @relation("OfferedCalendarWeek", fields: [offeredCalendarWeekId], references: [id], onDelete: Cascade)
  message               String?  @db.Text
  status                WeekPeerInterestStatus @default(PENDING)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requestId])
  @@index([interestedCotistaId])
  @@map("week_exchange_peer_interests")
}

model WeekExchangeEventLog {
  id         String   @id @default(cuid())
  requestId  String
  request    WeekExchangeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorType  String
  actorId    String?
  action     String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([createdAt])
  @@map("week_exchange_event_logs")
}

// ===== MARKETPLACE DE SEMANAS (cotista a cotista; sem pagamento no sistema) =====

enum WeekMarketplaceListingType {
  EXCHANGE
  SALE
  BOTH
}

enum WeekMarketplaceListingStatus {
  DRAFT
  PUBLISHED
  NEGOTIATING
  WAITING_CONFIRMATION
  COMPLETED
  CANCELLED
}

enum WeekMarketplaceProposalType {
  EXCHANGE
  SALE
}

enum WeekMarketplaceProposalStatus {
  PENDING
  ACCEPTED_BY_OWNER
  ACCEPTED_BY_PROPOSER
  REJECTED
  CANCELLED
  COMPLETED
}

enum WeekUsageOverrideReason {
  EXCHANGE
  SALE
}

/// Anúncio de semana para troca e/ou venda (por propriedade e ano).
model WeekMarketplaceListing {
  id                     String                       @id @default(cuid())
  propertyId             String
  property               Property                     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyCalendarYearId String
  calendarYear           PropertyCalendarYear         @relation(fields: [propertyCalendarYearId], references: [id], onDelete: Cascade)
  ownerCotistaId         String
  ownerCotista           Cotista                      @relation(fields: [ownerCotistaId], references: [id], onDelete: Cascade)
  ownerCotaId            String
  ownerCota              CotaPropriedade              @relation("ListingOwnerCota", fields: [ownerCotaId], references: [id], onDelete: Cascade)
  ownedCalendarWeekId    String
  ownedWeek              PropertyCalendarWeek           @relation(fields: [ownedCalendarWeekId], references: [id], onDelete: Restrict)
  type                   WeekMarketplaceListingType
  preferences            Json?
  status                 WeekMarketplaceListingStatus @default(DRAFT)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  proposals WeekMarketplaceProposal[]
  eventLogs WeekMarketplaceEventLog[]

  @@index([propertyId, status])
  @@index([ownerCotistaId])
  @@index([propertyCalendarYearId])
  @@index([ownedCalendarWeekId])
  @@map("week_marketplace_listings")
}

model WeekMarketplaceProposal {
  id                  String                        @id @default(cuid())
  listingId           String
  listing             WeekMarketplaceListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  proposerCotistaId   String
  proposerCotista     Cotista                       @relation(fields: [proposerCotistaId], references: [id], onDelete: Cascade)
  proposerCotaId      String
  proposerCota        CotaPropriedade               @relation("ProposerCota", fields: [proposerCotaId], references: [id], onDelete: Cascade)
  proposerWeekId      String?
  proposerWeek        PropertyCalendarWeek?         @relation("ProposerWeek", fields: [proposerWeekId], references: [id], onDelete: Restrict)
  type                WeekMarketplaceProposalType
  status              WeekMarketplaceProposalStatus @default(PENDING)
  /// Troca: dono aceitou a proposta em princípio.
  ownerAcceptedAt     DateTime?
  /// Troca: proponente confirmou o fechamento. Venda: comprador confirmou após o vendedor.
  proposerAcceptedAt  DateTime?
  /// Venda: vendedor (dono do listing) confirmou fora da plataforma.
  sellerConfirmedAt   DateTime?
  /// Venda: comprador confirmou fora da plataforma.
  buyerConfirmedAt    DateTime?
  message             String?                       @db.Text
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  usageOverrides WeekUsageOverride[]

  @@index([listingId])
  @@index([proposerCotistaId])
  @@index([status])
  @@map("week_marketplace_proposals")
}

/// Uso efetivo da semana no ano (não altera PropertyWeekAssignment).
model WeekUsageOverride {
  id                     String                 @id @default(cuid())
  propertyCalendarWeekId String
  calendarWeek           PropertyCalendarWeek   @relation(fields: [propertyCalendarWeekId], references: [id], onDelete: Cascade)
  fromCotaId             String
  fromCota               CotaPropriedade        @relation("UsageFromCota", fields: [fromCotaId], references: [id], onDelete: Cascade)
  toCotaId               String
  toCota                 CotaPropriedade        @relation("UsageToCota", fields: [toCotaId], references: [id], onDelete: Cascade)
  reason                 WeekUsageOverrideReason
  proposalId             String
  proposal               WeekMarketplaceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt              DateTime               @default(now())

  @@unique([propertyCalendarWeekId])
  @@index([fromCotaId])
  @@index([toCotaId])
  @@index([proposalId])
  @@map("week_usage_overrides")
}

model WeekMarketplaceEventLog {
  id        String                 @id @default(cuid())
  listingId String?
  listing   WeekMarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  actorCotistaId String?
  action    String
  payload   Json?
  createdAt DateTime               @default(now())

  @@index([listingId])
  @@index([createdAt])
  @@map("week_marketplace_event_logs")
}

// ===== COMERCIAL — CAPTAÇÃO DE IMÓVEIS =====
// Pipeline de imóveis em análise para aquisição (antes de virarem Property)

enum ImovelCaptacaoStatus {
  ANALISE_INICIAL
  EM_NEGOCIACAO
  PROPOSTA_ENVIADA
  DUE_DILIGENCE
  CONTRATO_ASSINADO
  ADQUIRIDO
  DECLINADO
  DESCARTADO
}

model ImovelCaptacao {
  id              String                @id @default(cuid())
  status          ImovelCaptacaoStatus  @default(ANALISE_INICIAL)

  // Identificação
  titulo          String
  tipo            String?               // Casa, Apartamento, Terreno, etc.

  // Localização
  destinoId       String?
  destino         Destination?          @relation(fields: [destinoId], references: [id], onDelete: SetNull)
  condominio      String?
  endereco        String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?

  // Áreas (m²)
  areaTotal       Decimal?              @db.Decimal(12, 2)
  areaTerreno     Decimal?              @db.Decimal(12, 2)
  areaConstruida  Decimal?              @db.Decimal(12, 2)

  // Valores (R$)
  valorPedido     Decimal?              @db.Decimal(15, 2) // Valor pedido pelo vendedor
  valorProposta   Decimal?              @db.Decimal(15, 2) // Nossa proposta
  valorAcordado   Decimal?              @db.Decimal(15, 2) // Valor final acordado
  valorReforma    Decimal?              @db.Decimal(15, 2) // Estimativa de reforma/adequação

  // Viabilidade financeira (dados para simulador de cotas)
  numCotas        Int?                                     // Número de cotas previstas
  valorCota       Decimal?              @db.Decimal(15, 2) // Valor por cota
  vgvEstimado     Decimal?              @db.Decimal(15, 2) // VGV estimado total
  margemEstimada  Decimal?              @db.Decimal(5, 2)  // Margem %
  taxaOcupacao    Decimal?              @db.Decimal(5, 2)  // Taxa de ocupação estimada %
  rentabilidadeAnual Decimal?           @db.Decimal(5, 2)  // Rentabilidade anual estimada %

  // Dados do vendedor (opcionais)
  vendedorNome      String?
  vendedorTelefone  String?
  vendedorEmail     String?
  vendedorCpfCnpj   String?
  vendedorObservacoes String?           @db.Text

  // Geral
  descricao           String?           @db.Text
  observacoes         String?           @db.Text
  motivoDeclinado     String?           @db.Text
  origem              String?           // Indicação, Google, Instagram, Parceiro, Visita, etc.

  // Responsável pela captação
  responsavelId   String?
  responsavel     User?                 @relation("CaptacaoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User                  @relation("CaptacaoCriador", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
  @@index([destinoId])
  @@index([responsavelId])
  @@index([createdAt])
  @@map("imoveis_captacao")
}

// ===== VIVANT CAPITAL (camada investimento sobre imóveis existentes) =====
// Não duplica propriedades: Property já existe; Capital só adiciona config e participações.

model CapitalAssetConfig {
  id                    String    @id @default(cuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  propertyId            String
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  fundId                String?
  fund                  CapitalFund? @relation(fields: [fundId], references: [id], onDelete: SetNull)
  enabled               Boolean   @default(true)
  totalCotas            Int       @default(100)
  valorPorCota          Decimal   @db.Decimal(15, 2)
  taxaAdministracaoPercent Decimal @db.Decimal(5, 2)
  reservaPercent        Decimal   @db.Decimal(5, 2)
  acquisitionValue      Decimal   @default(0) @db.Decimal(15, 2)
  structuredValue       Decimal   @default(0) @db.Decimal(15, 2)
  expectedReturnRate    Decimal   @default(0) @db.Decimal(8, 4)
  capRate               Decimal   @default(0) @db.Decimal(8, 4)
  operationalMarginMin  Decimal   @default(0) @db.Decimal(8, 4)
  operationalMarginMax  Decimal   @default(0) @db.Decimal(8, 4)
  ativoStatus           String    @default("ATIVO")  // ATIVO, PAUSADO, ENCERRADO
  observacoes           String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  participations        CapitalParticipation[]
  distributions         CapitalDistribution[]
  payments              CapitalPayment[]
  valuations           CapitalValuation[]
  liquidityRequests    CapitalLiquidityRequest[]
  complianceDocuments  CapitalComplianceDocument[]

  @@unique([companyId, propertyId])
  @@index([companyId])
  @@index([propertyId])
  @@index([fundId])
  @@index([enabled])
  @@index([ativoStatus])
  @@map("capital_asset_configs")
}

model CapitalInvestorProfile {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipoPessoa  String    @default("PF")  // PF, PJ
  documento   String?
  status      String    @default("ATIVO")  // ATIVO, INATIVO, PENDENTE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participations      CapitalParticipation[]
  distributionItems   CapitalDistributionItem[]
  liquidityRequests   CapitalLiquidityRequest[]
  payments            CapitalPayment[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("capital_investor_profiles")
}

model CapitalParticipation {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  assetConfigId     String
  assetConfig       CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  investorId        String?
  assetId           String?
  numeroCotas       Int
  quotas            Int       @default(0)
  percentualTotal   Decimal  @db.Decimal(5, 2)
  valorAportado     Decimal  @db.Decimal(15, 2)
  totalInvested     Decimal   @default(0) @db.Decimal(15, 2)
  expectedReturn    Decimal   @default(0) @db.Decimal(15, 2)
  roiPercent        Decimal   @default(0) @db.Decimal(8, 4)
  dataEntrada       DateTime @default(now())
  status            String   @default("ATIVO")  // ATIVO, RESGATADO, CANCELADO
  observacoes       String?  @db.Text
  reserveDate       DateTime?
  paymentDate       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payments          CapitalPayment[]

  @@unique([companyId, investorProfileId, assetConfigId])
  @@index([companyId])
  @@index([investorProfileId])
  @@index([assetConfigId])
  @@index([status])
  @@map("capital_participations")
}

model CapitalDistribution {
  id                    String    @id @default(cuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetConfigId         String
  assetConfig           CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  competencia          String    // ex: "2025-01"
  receitaBruta         Decimal   @db.Decimal(15, 2)
  custos               Decimal   @db.Decimal(15, 2)
  taxaAdministracaoValor Decimal @db.Decimal(15, 2)
  reservaValor         Decimal   @db.Decimal(15, 2)
  resultadoDistribuivel Decimal  @db.Decimal(15, 2)
  valorTotalDistribuido Decimal  @db.Decimal(15, 2)
  status               String    @default("RASCUNHO")  // RASCUNHO, APROVADA, PAGA
  dataAprovacao        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items                CapitalDistributionItem[]

  @@unique([companyId, assetConfigId, competencia])
  @@index([companyId])
  @@index([assetConfigId])
  @@index([status])
  @@index([competencia])
  @@map("capital_distributions")
}

model CapitalDistributionItem {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  distributionId    String
  distribution      CapitalDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  percentualAplicado Decimal  @db.Decimal(5, 2)
  valorDevido       Decimal   @db.Decimal(15, 2)
  valorPago         Decimal   @db.Decimal(15, 2)
  status            String    @default("PENDENTE")  // PENDENTE, PAGO
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([companyId, distributionId, investorProfileId])
  @@index([companyId])
  @@index([distributionId])
  @@index([investorProfileId])
  @@map("capital_distribution_items")
}

model CapitalValuation {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetConfigId String
  assetConfig   CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Cascade)
  dataReferencia DateTime
  valorImovel   Decimal   @db.Decimal(15, 2)
  observacoes   String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([assetConfigId])
  @@index([dataReferencia])
  @@map("capital_valuations")
}

model CapitalLiquidityRequest {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  assetConfigId     String
  assetConfig       CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  tipoSolicitacao   String    // ANTECIPACAO, RESGATE
  valorSolicitado   Decimal   @db.Decimal(15, 2)
  motivo            String?   @db.Text
  status            String    @default("PENDENTE")  // PENDENTE, APROVADA, RECUSADA, PAGA
  observacaoAdmin   String?   @db.Text
  dataSolicitacao   DateTime  @default(now())
  dataDecisao       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([investorProfileId])
  @@index([assetConfigId])
  @@index([status])
  @@map("capital_liquidity_requests")
}

model CapitalFund {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assets     CapitalAssetConfig[]

  @@index([companyId])
  @@unique([companyId, name])
  @@map("capital_funds")
}

model CapitalPayment {
  id                          String    @id @default(cuid())
  companyId                   String
  company                     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investmentId                String
  investment                  CapitalParticipation @relation(fields: [investmentId], references: [id], onDelete: Restrict)
  investorId                  String
  investor                    CapitalInvestorProfile @relation(fields: [investorId], references: [id], onDelete: Restrict)
  assetId                     String
  asset                       CapitalAssetConfig @relation(fields: [assetId], references: [id], onDelete: Restrict)
  amount                      Decimal   @db.Decimal(15, 2)
  guaranteeAmount             Decimal   @db.Decimal(15, 2)
  operationAmount             Decimal   @db.Decimal(15, 2)
  splitPercentageGuarantee    Decimal   @db.Decimal(5, 2)
  splitPercentageOperation    Decimal   @db.Decimal(5, 2)
  paidAt                      DateTime?
  status                      String    @default("PENDENTE")
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([companyId])
  @@index([investmentId])
  @@index([investorId])
  @@index([assetId])
  @@index([status])
  @@map("capital_payments")
}

model CapitalWallet {
  id                     String   @id @default(cuid())
  companyId              String   @unique
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  totalGuaranteeBalance  Decimal  @default(0) @db.Decimal(15, 2)
  totalOperationBalance  Decimal  @default(0) @db.Decimal(15, 2)
  totalReceived          Decimal  @default(0) @db.Decimal(15, 2)
  totalDistributed       Decimal  @default(0) @db.Decimal(15, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  transactions           CapitalTransaction[]

  @@index([companyId])
  @@map("capital_wallets")
}

model CapitalTransaction {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  walletId    String?
  wallet      CapitalWallet? @relation(fields: [walletId], references: [id], onDelete: SetNull)
  type        String   // IN | OUT
  category    String   // INVESTMENT | GUARANTEE | OPERATION | DISTRIBUTION
  amount      Decimal  @db.Decimal(15, 2)
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([walletId])
  @@index([referenceId])
  @@index([type])
  @@index([category])
  @@map("capital_transactions")
}

model CapitalComplianceDocument {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetId        String
  asset          CapitalAssetConfig @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type           String   // AFETACAO, FIDUCIARIA, CRI, ESCROW, AUDITORIA
  status         String   @default("PENDENTE")
  fileUrl        String?
  observations   String?  @db.Text
  concludedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, assetId, type])
  @@index([companyId])
  @@index([assetId])
  @@index([type])
  @@index([status])
  @@map("capital_compliance_documents")
}

model CapitalSettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  guaranteePercentage Decimal  @default(50) @db.Decimal(5, 2)
  operationPercentage Decimal  @default(50) @db.Decimal(5, 2)
  defaultReturnRate   Decimal  @default(12) @db.Decimal(8, 4)
  marginMin           Decimal  @default(18) @db.Decimal(8, 4)
  marginMax           Decimal  @default(35) @db.Decimal(8, 4)
  disclaimer          String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@map("capital_settings")
}
