generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// ===== MULTI-TENANT (opcional) =====
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoleAssignments UserRoleAssignment[]
  userPermissions UserPermission[]

  @@map("companies")
}

// ===== AUTENTICAÇÃO =====

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          UserRole  @default(EDITOR)
  active        Boolean   @default(true)
  defaultRoute  String?   // rota padrão pós-login (ex: /admin, /admin-portal, /dashboard)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  destinations  Destination[]
  auditLogs     AuditLog[]
  userRoleAssignments UserRoleAssignment[]
  userPermissions UserPermission[]
  tutorialProgress UserTutorialProgress[]
  leadsOwned    Lead[]
  leadActivities LeadActivity[]
  leadTypeAssignmentsAsDefault LeadTypeAssignment[]
  systemTasksAssigned          SystemTask[]
  systemEvents                SystemEvent[]
  capitalInvestorProfile       CapitalInvestorProfile?

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

// ===== RBAC (Roles & Permissions) =====
model Role {
  id          String   @id @default(cuid())
  key         String   @unique  // SUPER_ADMIN, ADMIN, STAFF, COTISTA
  name        String
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoleAssignments UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique  // users.manage, roles.manage, etc.
  name        String
  description String?  @db.Text
  group       String   // agrupamento: admin, dashboard, cotista, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions  RolePermission[]
  userPermissions  UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  companyId String?  // null = global
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([roleId])
  @@index([companyId])
  @@map("user_roles")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  companyId    String?    // null = global (override)
  granted      Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, companyId])
  @@index([permissionId])
  @@index([companyId])
  @@map("user_permissions")
}

// ===== TUTORIAL (progresso por módulo) =====
model UserTutorialProgress {
  id          String    @id @default(cuid())
  userId      String
  key         String    // ex: dashboard, admin, cotista
  completedAt DateTime?
  dismissedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_tutorial_progress")
}

// ===== AJUDA CONTEXTUAL (HelpTip) =====
model HelpContent {
  id           String   @id @default(cuid())
  key          String   @unique  // ex: properties.name, users.email
  title        String
  description  String?  @db.Text
  shortText    String?  @db.Text
  videoUrl     String?
  audienceRole String?  // null = todos; ou SUPER_ADMIN, ADMIN, etc.
  updatedAt    DateTime @updatedAt

  @@index([key])
  @@map("help_contents")
}

// ===== TELEMETRIA DONO (eventos + pendências) =====
enum SystemEventSeverity {
  INFO
  WARN
  CRITICAL
}

enum SystemEventStatus {
  OK
  PENDING
  FAILED
}

model SystemEvent {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now())
  actorUserId   String?
  actorUser     User?               @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole     String?
  type          String
  entityType    String?
  entityId      String?
  productKey    String?
  severity      SystemEventSeverity  @default(INFO)
  status        SystemEventStatus    @default(OK)
  message       String              @db.Text
  meta          Json?

  @@index([createdAt])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([actorUserId])
  @@map("system_events")
}

enum SystemTaskStatus {
  OPEN
  DONE
  CANCELED
}

enum SystemTaskPriority {
  LOW
  MED
  HIGH
}

model SystemTask {
  id                String            @id @default(cuid())
  createdAt         DateTime          @default(now())
  dueAt             DateTime?
  status            SystemTaskStatus   @default(OPEN)
  title             String
  description       String?           @db.Text
  assignedToUserId  String?
  assignedTo        User?             @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  relatedEntityType String?
  relatedEntityId   String?
  productKey        String?
  priority          SystemTaskPriority @default(MED)
  meta              Json?

  @@index([status])
  @@index([dueAt])
  @@index([assignedToUserId])
  @@map("system_tasks")
}

// ===== CRM — Motor de Funil Configurável =====
model LeadType {
  id              String    @id @default(cuid())
  key             String    @unique
  name            String
  description     String?   @db.Text
  isActive        Boolean   @default(true)
  order           Int       @default(0)
  initialStageId  String?
  initialStage    LeadStage? @relation("InitialStage", fields: [initialStageId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stages LeadStage[]
  leads  Lead[]
  lossReasons LeadLossReason[]
  assignment LeadTypeAssignment?

  @@map("lead_types")
}

model LeadTypeAssignment {
  id                 String   @id @default(cuid())
  leadTypeId         String   @unique
  leadType           LeadType @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  defaultOwnerUserId String
  defaultOwner       User     @relation(fields: [defaultOwnerUserId], references: [id], onDelete: Restrict)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([leadTypeId])
  @@index([defaultOwnerUserId])
  @@map("lead_type_assignments")
}

model LeadLossReason {
  id         String   @id @default(cuid())
  leadTypeId String
  leadType   LeadType @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  leads Lead[]

  @@unique([leadTypeId, order])
  @@index([leadTypeId])
  @@map("lead_loss_reasons")
}

model LeadStage {
  id                String    @id @default(cuid())
  leadTypeId        String
  leadType          LeadType  @relation(fields: [leadTypeId], references: [id], onDelete: Cascade)
  name              String
  order             Int
  isFinal           Boolean   @default(false)
  finalStatus       LeadFinalStatus?
  slaEnabled        Boolean   @default(true)
  slaHours          Int?
  slaThresholds    Json?     // [{ color: "YELLOW", hoursLeft: 12 }, { color: "ORANGE", hoursLeft: 3 }] ordenado menor primeiro
  isActive          Boolean   @default(true)
  whatsTemplate     String?   @db.Text
  playbookChecklist Json?     // array de strings
  nextActionType    String?   // CALL | WHATSAPP | PROPOSAL | VISIT | NOTE
  helpText          String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  leads Lead[]
  typesUsingAsInitial LeadType[] @relation("InitialStage")
  slaEvents LeadSlaEvent[]

  @@unique([leadTypeId, order])
  @@index([leadTypeId])
  @@map("lead_stages")
}

enum LeadFinalStatus {
  WON
  LOST
}

model Lead {
  id               String        @id @default(cuid())
  leadTypeId       String
  leadType         LeadType      @relation(fields: [leadTypeId], references: [id], onDelete: Restrict)
  stageId          String
  stage            LeadStage     @relation(fields: [stageId], references: [id], onDelete: Restrict)
  ownerUserId      String
  owner            User          @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  name             String
  phone            String
  email            String
  city             String?       // captação pública
  source           String?
  origin           String?       // Como conheceu: Google, Instagram, Indicação, etc.
  notes            String?       @db.Text
  status           LeadStatus    @default(ACTIVE)
  lossReasonId     String?
  lossReason       LeadLossReason? @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)
  stageEnteredAt   DateTime?
  stageDueAt       DateTime?
  stageBreachedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  activities LeadActivity[]
  slaEvents  LeadSlaEvent[]

  @@index([leadTypeId])
  @@index([stageId])
  @@index([ownerUserId])
  @@index([status])
  @@index([lossReasonId])
  @@index([stageDueAt])
  @@index([ownerUserId, stageDueAt])
  @@map("leads")
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
}

model LeadActivity {
  id          String        @id @default(cuid())
  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorUserId String
  actor       User          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  type        LeadActivityType
  message     String?       @db.Text
  meta        Json?
  createdAt   DateTime      @default(now())

  @@index([leadId])
  @@index([actorUserId])
  @@map("lead_activities")
}

enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  VISIT
  PROPOSAL
  STATUS_CHANGE
}

enum LeadSlaEventType {
  STAGE_CHANGED
  SLA_WARNING
  SLA_BREACHED
  SLA_RESOLVED
}

model LeadSlaEvent {
  id        String           @id @default(cuid())
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stageId   String
  stage     LeadStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  type      LeadSlaEventType
  meta      Json?
  createdAt DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([createdAt])
  @@map("lead_sla_events")
}

// ===== CONTEÚDO =====

model Property {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String          @default("") @db.Text
  location        String
  cidade          String
  destinoId       String
  destino         Destination     @relation(fields: [destinoId], references: [id], onDelete: Restrict)
  condominio      String
  type            String
  priceValue      Int
  bedrooms        Int
  bathrooms       Int
  area            Int
  maxGuests       Int?
  fraction        String
  price           String
  monthlyFee      String
  weeks           String
  totalCotas      Int?
  images          Json
  features        Json
  appreciation    String
  status          PropertyStatus  @default(DISPONIVEL)
  highlight       Boolean         @default(false)
  published       Boolean         @default(false)
  publishedAt     DateTime?
  
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relações com portal do cotista
  cotas           CotaPropriedade[]
  assembleias     Assembleia[]
  mensagens       Mensagem[]
  documentos      Documento[]
  // Vivant Capital: camada de investimento sobre o imóvel (sem duplicar dados)
  capitalAssetConfigs CapitalAssetConfig[]

  @@index([destinoId])
  @@index([published])
  @@index([slug])
  @@map("properties")
}

enum PropertyStatus {
  DISPONIVEL
  ULTIMAS_COTAS
  PRE_LANCAMENTO
  VENDIDO
}

model Destination {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  state           String
  emoji           String
  color           String
  subtitle        String
  location        String
  description     String   @db.Text
  climate         String   @db.Text
  lifestyle       String   @db.Text
  features        Json
  appreciation    String
  published       Boolean  @default(false)
  publishedAt     DateTime?
  order           Int      @default(0)
  
  properties      Property[]
  
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([published])
  @@index([slug])
  @@index([order])
  @@map("destinations")
}

// ===== AUDITORIA =====

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===== COTISTAS E MULTIPROPRIEDADE =====

model Cotista {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  cpf               String              @unique
  phone             String?
  password          String
  avatar            String?
  active            Boolean             @default(true)
  emailVerified     DateTime?
  
  inviteToken       String?             @unique
  inviteTokenExpiry DateTime?
  invitedBy         String?
  invitedAt         DateTime?
  
  cotas             CotaPropriedade[]
  reservas          Reserva[]
  trocasSemanas     TrocaSemana[]
  votosAssembleia   VotoAssembleia[]
  mensagens         Mensagem[]
  notificacoes      Notificacao[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([email])
  @@index([cpf])
  @@index([inviteToken])
  @@map("cotistas")
}

model CotaPropriedade {
  id                String          @id @default(cuid())
  cotistaId         String
  cotista           Cotista         @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  propertyId        String
  property          Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  
  numeroCota        String
  percentualCota    Decimal         @db.Decimal(5,2)
  semanasAno        Int             @default(8)
  semanasConfig     Json
  
  ativo             Boolean         @default(true)
  dataAquisicao     DateTime        @default(now())
  
  cobrancas         Cobranca[]
  reservas          Reserva[]
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@unique([cotistaId, propertyId, numeroCota])
  @@index([cotistaId])
  @@index([propertyId])
  @@map("cotas_propriedade")
}

// ===== CALENDÁRIO E RESERVAS =====

model Reserva {
  id                String              @id @default(cuid())
  cotaId            String
  cota              CotaPropriedade     @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  cotistaId         String
  cotista           Cotista             @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  
  ano               Int
  numeroSemana      Int
  dataInicio        DateTime
  dataFim           DateTime
  
  status            StatusReserva       @default(PENDENTE)
  confirmadoEm      DateTime?
  checkInEm         DateTime?
  checkOutEm        DateTime?
  
  limpezaSolicitada Boolean             @default(false)
  limpezaRealizada  Boolean             @default(false)
  
  observacoes       String?             @db.Text
  
  trocaId           String?
  troca             TrocaSemana?        @relation(fields: [trocaId], references: [id])
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([cotaId, ano, numeroSemana])
  @@index([cotistaId])
  @@index([status])
  @@index([ano, numeroSemana])
  @@map("reservas")
}

enum StatusReserva {
  PENDENTE
  CONFIRMADA
  NAO_UTILIZADA
  EM_USO
  FINALIZADA
  CANCELADA
  DISPONIVEL_TROCA
}

model TrocaSemana {
  id                String          @id @default(cuid())
  
  cotistaSolicitante String
  solicitante        Cotista        @relation(fields: [cotistaSolicitante], references: [id], onDelete: Cascade)
  
  reservaOferecida   String?
  
  status             StatusTroca    @default(ABERTA)
  tipo               TipoTroca      @default(QUALQUER_PROPRIEDADE)
  
  propriedadeDesejada String?
  semanasDesejadas    Json?
  observacoes         String?       @db.Text
  
  cotistaConclusao    String?
  reservaRecebida     String?
  concluidaEm         DateTime?
  
  reservas            Reserva[]
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  @@index([cotistaSolicitante])
  @@index([status])
  @@map("trocas_semanas")
}

enum StatusTroca {
  ABERTA
  EM_NEGOCIACAO
  ACEITA
  CONCLUIDA
  CANCELADA
  EXPIRADA
}

enum TipoTroca {
  MESMA_PROPRIEDADE
  QUALQUER_PROPRIEDADE
  PROPRIEDADE_ESPECIFICA
}

// ===== FINANCEIRO =====

model Cobranca {
  id                String              @id @default(cuid())
  cotaId            String
  cota              CotaPropriedade     @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  
  tipo              TipoCobranca
  descricao         String
  
  valor             Decimal             @db.Decimal(10,2)
  valorPago         Decimal             @default(0) @db.Decimal(10,2)
  
  mesReferencia     Int
  anoReferencia     Int
  
  dataVencimento    DateTime
  dataPagamento     DateTime?
  
  status            StatusCobranca      @default(PENDENTE)
  
  urlBoleto         String?
  urlComprovante    String?
  
  observacoes       String?             @db.Text
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([cotaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([anoReferencia, mesReferencia])
  @@map("cobrancas")
}

enum TipoCobranca {
  CONDOMINIO
  LIMPEZA
  MANUTENCAO
  SEGURO
  IPTU
  TAXA_GESTAO
  OUTROS
}

enum StatusCobranca {
  PENDENTE
  VENCIDA
  PAGA
  PAGA_PARCIAL
  CANCELADA
}

// ===== ASSEMBLEIAS E VOTAÇÕES =====

model Assembleia {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String              @db.Text
  tipo              TipoAssembleia
  
  dataRealizacao    DateTime
  dataInicio        DateTime
  dataFim           DateTime
  
  status            StatusAssembleia    @default(AGENDADA)
  
  quorumMinimo      Decimal             @db.Decimal(5,2)
  quorumAlcancado   Decimal?            @db.Decimal(5,2)
  
  ataUrl            String?
  documentosUrls    Json?
  
  pautas            PautaAssembleia[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([status])
  @@index([dataRealizacao])
  @@map("assembleias")
}

enum TipoAssembleia {
  ORDINARIA
  EXTRAORDINARIA
  VIRTUAL
}

enum StatusAssembleia {
  AGENDADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

model PautaAssembleia {
  id                String              @id @default(cuid())
  assembleiaId      String
  assembleia        Assembleia          @relation(fields: [assembleiaId], references: [id], onDelete: Cascade)
  
  ordem             Int
  titulo            String
  descricao         String              @db.Text
  tipo              TipoPauta
  
  requererVotacao   Boolean             @default(false)
  votacaoAberta     Boolean             @default(false)
  
  votos             VotoAssembleia[]
  
  aprovada          Boolean?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([assembleiaId])
  @@map("pautas_assembleia")
}

enum TipoPauta {
  INFORMATIVA
  DELIBERATIVA
  ELETIVA
}

model VotoAssembleia {
  id                String              @id @default(cuid())
  pautaId           String
  pauta             PautaAssembleia     @relation(fields: [pautaId], references: [id], onDelete: Cascade)
  cotistaId         String
  cotista           Cotista             @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  
  voto              TipoVoto
  justificativa     String?             @db.Text
  
  votadoEm          DateTime            @default(now())
  
  @@unique([pautaId, cotistaId])
  @@index([pautaId])
  @@index([cotistaId])
  @@map("votos_assembleia")
}

enum TipoVoto {
  FAVOR
  CONTRA
  ABSTENCAO
}

// ===== COMUNICAÇÃO E DOCUMENTOS =====

model Mensagem {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  autorId           String?
  autor             Cotista?            @relation(fields: [autorId], references: [id], onDelete: SetNull)
  autorNome         String
  autorTipo         TipoAutor           @default(ADMINISTRACAO)
  
  titulo            String
  conteudo          String              @db.Text
  tipo              TipoMensagem        @default(AVISO)
  prioridade        PrioridadeMensagem  @default(NORMAL)
  
  anexosUrls        Json?
  
  fixada            Boolean             @default(false)
  ativa             Boolean             @default(true)
  
  visualizacoes     VisualizacaoMensagem[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@index([createdAt])
  @@map("mensagens")
}

enum TipoAutor {
  ADMINISTRACAO
  COTISTA
  SISTEMA
}

enum TipoMensagem {
  AVISO
  COMUNICADO
  URGENTE
  MANUTENCAO
  EVENTO
  LEMBRETE
}

enum PrioridadeMensagem {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

model VisualizacaoMensagem {
  id                String          @id @default(cuid())
  mensagemId        String
  mensagem          Mensagem        @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  cotistaId         String
  
  visualizadoEm     DateTime        @default(now())
  
  @@unique([mensagemId, cotistaId])
  @@index([mensagemId])
  @@map("visualizacoes_mensagem")
}

model Documento {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String?             @db.Text
  tipo              TipoDocumento
  categoria         String?
  
  url               String
  nomeArquivo       String
  tamanhoBytes      Int
  mimeType          String
  
  versao            String              @default("1.0")
  ativo             Boolean             @default(true)
  
  uploadedBy        String?
  uploadedAt        DateTime            @default(now())
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@map("documentos")
}

enum TipoDocumento {
  ESTATUTO
  REGIMENTO_INTERNO
  ATA
  CONTRATO
  MANUAL
  PLANTA
  LAUDO
  OUTROS
}

// ===== NOTIFICAÇÕES =====

model Notificacao {
  id           String   @id @default(cuid())
  cotistaId    String
  cotista      Cotista  @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  tipo         String
  titulo       String
  mensagem     String   @db.Text
  lida         Boolean  @default(false)
  url          String?
  createdAt    DateTime @default(now())
  
  @@index([cotistaId])
  @@index([lida])
  @@index([createdAt])
  @@map("notificacoes")
}

// ===== VIVANT CAPITAL (camada investimento sobre imóveis existentes) =====
// Não duplica propriedades: Property já existe; Capital só adiciona config e participações.

model CapitalAssetConfig {
  id                    String    @id @default(cuid())
  propertyId            String    @unique
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  enabled               Boolean   @default(true)
  totalCotas            Int       @default(100)
  valorPorCota          Decimal   @db.Decimal(15, 2)
  taxaAdministracaoPercent Decimal @db.Decimal(5, 2)
  reservaPercent        Decimal   @db.Decimal(5, 2)
  ativoStatus           String    @default("ATIVO")  // ATIVO, PAUSADO, ENCERRADO
  observacoes           String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  participations        CapitalParticipation[]
  distributions         CapitalDistribution[]
  valuations           CapitalValuation[]
  liquidityRequests    CapitalLiquidityRequest[]

  @@index([propertyId])
  @@index([enabled])
  @@index([ativoStatus])
  @@map("capital_asset_configs")
}

model CapitalInvestorProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipoPessoa  String    @default("PF")  // PF, PJ
  documento   String?
  status      String    @default("ATIVO")  // ATIVO, INATIVO, PENDENTE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participations      CapitalParticipation[]
  distributionItems   CapitalDistributionItem[]
  liquidityRequests   CapitalLiquidityRequest[]

  @@index([userId])
  @@index([status])
  @@map("capital_investor_profiles")
}

model CapitalParticipation {
  id                String    @id @default(cuid())
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  assetConfigId     String
  assetConfig       CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  numeroCotas       Int
  percentualTotal   Decimal  @db.Decimal(5, 2)
  valorAportado     Decimal  @db.Decimal(15, 2)
  dataEntrada       DateTime @default(now())
  status            String   @default("ATIVO")  // ATIVO, RESGATADO, CANCELADO
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([investorProfileId, assetConfigId])
  @@index([investorProfileId])
  @@index([assetConfigId])
  @@index([status])
  @@map("capital_participations")
}

model CapitalDistribution {
  id                    String    @id @default(cuid())
  assetConfigId         String
  assetConfig           CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  competencia          String    // ex: "2025-01"
  receitaBruta         Decimal   @db.Decimal(15, 2)
  custos               Decimal   @db.Decimal(15, 2)
  taxaAdministracaoValor Decimal @db.Decimal(15, 2)
  reservaValor         Decimal   @db.Decimal(15, 2)
  resultadoDistribuivel Decimal  @db.Decimal(15, 2)
  valorTotalDistribuido Decimal  @db.Decimal(15, 2)
  status               String    @default("RASCUNHO")  // RASCUNHO, APROVADA, PAGA
  dataAprovacao        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items                CapitalDistributionItem[]

  @@unique([assetConfigId, competencia])
  @@index([assetConfigId])
  @@index([status])
  @@index([competencia])
  @@map("capital_distributions")
}

model CapitalDistributionItem {
  id                String    @id @default(cuid())
  distributionId    String
  distribution      CapitalDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  percentualAplicado Decimal  @db.Decimal(5, 2)
  valorDevido       Decimal   @db.Decimal(15, 2)
  valorPago         Decimal   @db.Decimal(15, 2)
  status            String    @default("PENDENTE")  // PENDENTE, PAGO
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([distributionId, investorProfileId])
  @@index([distributionId])
  @@index([investorProfileId])
  @@map("capital_distribution_items")
}

model CapitalValuation {
  id            String    @id @default(cuid())
  assetConfigId String
  assetConfig   CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Cascade)
  dataReferencia DateTime
  valorImovel   Decimal   @db.Decimal(15, 2)
  observacoes   String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([assetConfigId])
  @@index([dataReferencia])
  @@map("capital_valuations")
}

model CapitalLiquidityRequest {
  id                String    @id @default(cuid())
  investorProfileId String
  investorProfile   CapitalInvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  assetConfigId     String
  assetConfig       CapitalAssetConfig @relation(fields: [assetConfigId], references: [id], onDelete: Restrict)
  tipoSolicitacao   String    // ANTECIPACAO, RESGATE
  valorSolicitado   Decimal   @db.Decimal(15, 2)
  motivo            String?   @db.Text
  status            String    @default("PENDENTE")  // PENDENTE, APROVADA, RECUSADA, PAGA
  observacaoAdmin   String?   @db.Text
  dataSolicitacao   DateTime  @default(now())
  dataDecisao       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([investorProfileId])
  @@index([assetConfigId])
  @@index([status])
  @@map("capital_liquidity_requests")
}
