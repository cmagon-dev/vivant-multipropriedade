generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// ===== AUTENTICAÇÃO =====

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          UserRole  @default(EDITOR)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  properties    Property[]
  destinations  Destination[]
  auditLogs     AuditLog[]
  
  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

// ===== CONTEÚDO =====

model Property {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String          @default("") @db.Text
  location        String
  cidade          String
  destinoId       String
  destino         Destination     @relation(fields: [destinoId], references: [id], onDelete: Restrict)
  condominio      String
  type            String
  priceValue      Int
  bedrooms        Int
  bathrooms       Int
  area            Int
  maxGuests       Int?
  fraction        String
  price           String
  monthlyFee      String
  weeks           String
  totalCotas      Int?
  images          Json
  features        Json
  appreciation    String
  status          PropertyStatus  @default(DISPONIVEL)
  highlight       Boolean         @default(false)
  published       Boolean         @default(false)
  publishedAt     DateTime?
  
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relações com portal do cotista
  cotas           CotaPropriedade[]
  assembleias     Assembleia[]
  mensagens       Mensagem[]
  documentos      Documento[]
  
  @@index([destinoId])
  @@index([published])
  @@index([slug])
  @@map("properties")
}

enum PropertyStatus {
  DISPONIVEL
  ULTIMAS_COTAS
  PRE_LANCAMENTO
  VENDIDO
}

model Destination {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  state           String
  emoji           String
  color           String
  subtitle        String
  location        String
  description     String   @db.Text
  climate         String   @db.Text
  lifestyle       String   @db.Text
  images          Json     @default("[]")
  features        Json
  appreciation    String
  published       Boolean  @default(false)
  publishedAt     DateTime?
  order           Int      @default(0)
  
  properties      Property[]
  
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([published])
  @@index([slug])
  @@index([order])
  @@map("destinations")
}

// ===== AUDITORIA =====

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===== COTISTAS E MULTIPROPRIEDADE =====

model Cotista {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  cpf               String              @unique
  phone             String?
  password          String
  avatar            String?
  active            Boolean             @default(true)
  emailVerified     DateTime?
  
  inviteToken       String?             @unique
  inviteTokenExpiry DateTime?
  invitedBy         String?
  invitedAt         DateTime?
  
  cotas             CotaPropriedade[]
  reservas          Reserva[]
  trocasSemanas     TrocaSemana[]
  votosAssembleia   VotoAssembleia[]
  mensagens         Mensagem[]
  notificacoes      Notificacao[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([email])
  @@index([cpf])
  @@index([inviteToken])
  @@map("cotistas")
}

model CotaPropriedade {
  id                String          @id @default(cuid())
  cotistaId         String
  cotista           Cotista         @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  propertyId        String
  property          Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  
  numeroCota        String
  percentualCota    Decimal         @db.Decimal(5,2)
  semanasAno        Int             @default(8)
  semanasConfig     Json
  
  ativo             Boolean         @default(true)
  dataAquisicao     DateTime        @default(now())
  
  cobrancas         Cobranca[]
  reservas          Reserva[]
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@unique([cotistaId, propertyId, numeroCota])
  @@index([cotistaId])
  @@index([propertyId])
  @@map("cotas_propriedade")
}

// ===== CALENDÁRIO E RESERVAS =====

model Reserva {
  id                String              @id @default(cuid())
  cotaId            String
  cota              CotaPropriedade     @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  cotistaId         String
  cotista           Cotista             @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  
  ano               Int
  numeroSemana      Int
  dataInicio        DateTime
  dataFim           DateTime
  
  status            StatusReserva       @default(PENDENTE)
  confirmadoEm      DateTime?
  checkInEm         DateTime?
  checkOutEm        DateTime?
  
  limpezaSolicitada Boolean             @default(false)
  limpezaRealizada  Boolean             @default(false)
  
  observacoes       String?             @db.Text
  
  trocaId           String?
  troca             TrocaSemana?        @relation(fields: [trocaId], references: [id])
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([cotaId, ano, numeroSemana])
  @@index([cotistaId])
  @@index([status])
  @@index([ano, numeroSemana])
  @@map("reservas")
}

enum StatusReserva {
  PENDENTE
  CONFIRMADA
  NAO_UTILIZADA
  EM_USO
  FINALIZADA
  CANCELADA
  DISPONIVEL_TROCA
}

model TrocaSemana {
  id                String          @id @default(cuid())
  
  cotistaSolicitante String
  solicitante        Cotista        @relation(fields: [cotistaSolicitante], references: [id], onDelete: Cascade)
  
  reservaOferecida   String?
  
  status             StatusTroca    @default(ABERTA)
  tipo               TipoTroca      @default(QUALQUER_PROPRIEDADE)
  
  propriedadeDesejada String?
  semanasDesejadas    Json?
  observacoes         String?       @db.Text
  
  cotistaConclusao    String?
  reservaRecebida     String?
  concluidaEm         DateTime?
  
  reservas            Reserva[]
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  @@index([cotistaSolicitante])
  @@index([status])
  @@map("trocas_semanas")
}

enum StatusTroca {
  ABERTA
  EM_NEGOCIACAO
  ACEITA
  CONCLUIDA
  CANCELADA
  EXPIRADA
}

enum TipoTroca {
  MESMA_PROPRIEDADE
  QUALQUER_PROPRIEDADE
  PROPRIEDADE_ESPECIFICA
}

// ===== FINANCEIRO =====

model Cobranca {
  id                String              @id @default(cuid())
  cotaId            String
  cota              CotaPropriedade     @relation(fields: [cotaId], references: [id], onDelete: Cascade)
  
  tipo              TipoCobranca
  descricao         String
  
  valor             Decimal             @db.Decimal(10,2)
  valorPago         Decimal             @default(0) @db.Decimal(10,2)
  
  mesReferencia     Int
  anoReferencia     Int
  
  dataVencimento    DateTime
  dataPagamento     DateTime?
  
  status            StatusCobranca      @default(PENDENTE)
  
  urlBoleto         String?
  urlComprovante    String?
  
  observacoes       String?             @db.Text
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([cotaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([anoReferencia, mesReferencia])
  @@map("cobrancas")
}

enum TipoCobranca {
  CONDOMINIO
  LIMPEZA
  MANUTENCAO
  SEGURO
  IPTU
  TAXA_GESTAO
  OUTROS
}

enum StatusCobranca {
  PENDENTE
  VENCIDA
  PAGA
  PAGA_PARCIAL
  CANCELADA
}

// ===== ASSEMBLEIAS E VOTAÇÕES =====

model Assembleia {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String              @db.Text
  tipo              TipoAssembleia
  
  dataRealizacao    DateTime
  dataInicio        DateTime
  dataFim           DateTime
  
  status            StatusAssembleia    @default(AGENDADA)
  
  quorumMinimo      Decimal             @db.Decimal(5,2)
  quorumAlcancado   Decimal?            @db.Decimal(5,2)
  
  ataUrl            String?
  documentosUrls    Json?
  
  pautas            PautaAssembleia[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([status])
  @@index([dataRealizacao])
  @@map("assembleias")
}

enum TipoAssembleia {
  ORDINARIA
  EXTRAORDINARIA
  VIRTUAL
}

enum StatusAssembleia {
  AGENDADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

model PautaAssembleia {
  id                String              @id @default(cuid())
  assembleiaId      String
  assembleia        Assembleia          @relation(fields: [assembleiaId], references: [id], onDelete: Cascade)
  
  ordem             Int
  titulo            String
  descricao         String              @db.Text
  tipo              TipoPauta
  
  requererVotacao   Boolean             @default(false)
  votacaoAberta     Boolean             @default(false)
  
  votos             VotoAssembleia[]
  
  aprovada          Boolean?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([assembleiaId])
  @@map("pautas_assembleia")
}

enum TipoPauta {
  INFORMATIVA
  DELIBERATIVA
  ELETIVA
}

model VotoAssembleia {
  id                String              @id @default(cuid())
  pautaId           String
  pauta             PautaAssembleia     @relation(fields: [pautaId], references: [id], onDelete: Cascade)
  cotistaId         String
  cotista           Cotista             @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  
  voto              TipoVoto
  justificativa     String?             @db.Text
  
  votadoEm          DateTime            @default(now())
  
  @@unique([pautaId, cotistaId])
  @@index([pautaId])
  @@index([cotistaId])
  @@map("votos_assembleia")
}

enum TipoVoto {
  FAVOR
  CONTRA
  ABSTENCAO
}

// ===== COMUNICAÇÃO E DOCUMENTOS =====

model Mensagem {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  autorId           String?
  autor             Cotista?            @relation(fields: [autorId], references: [id], onDelete: SetNull)
  autorNome         String
  autorTipo         TipoAutor           @default(ADMINISTRACAO)
  
  titulo            String
  conteudo          String              @db.Text
  tipo              TipoMensagem        @default(AVISO)
  prioridade        PrioridadeMensagem  @default(NORMAL)
  
  anexosUrls        Json?
  
  fixada            Boolean             @default(false)
  ativa             Boolean             @default(true)
  
  visualizacoes     VisualizacaoMensagem[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@index([createdAt])
  @@map("mensagens")
}

enum TipoAutor {
  ADMINISTRACAO
  COTISTA
  SISTEMA
}

enum TipoMensagem {
  AVISO
  COMUNICADO
  URGENTE
  MANUTENCAO
  EVENTO
  LEMBRETE
}

enum PrioridadeMensagem {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

model VisualizacaoMensagem {
  id                String          @id @default(cuid())
  mensagemId        String
  mensagem          Mensagem        @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  cotistaId         String
  
  visualizadoEm     DateTime        @default(now())
  
  @@unique([mensagemId, cotistaId])
  @@index([mensagemId])
  @@map("visualizacoes_mensagem")
}

model Documento {
  id                String              @id @default(cuid())
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  titulo            String
  descricao         String?             @db.Text
  tipo              TipoDocumento
  categoria         String?
  
  url               String
  nomeArquivo       String
  tamanhoBytes      Int
  mimeType          String
  
  versao            String              @default("1.0")
  ativo             Boolean             @default(true)
  
  uploadedBy        String?
  uploadedAt        DateTime            @default(now())
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([propertyId])
  @@index([tipo])
  @@map("documentos")
}

enum TipoDocumento {
  ESTATUTO
  REGIMENTO_INTERNO
  ATA
  CONTRATO
  MANUAL
  PLANTA
  LAUDO
  OUTROS
}

// ===== NOTIFICAÇÕES =====

model Notificacao {
  id           String   @id @default(cuid())
  cotistaId    String
  cotista      Cotista  @relation(fields: [cotistaId], references: [id], onDelete: Cascade)
  tipo         String
  titulo       String
  mensagem     String   @db.Text
  lida         Boolean  @default(false)
  url          String?
  createdAt    DateTime @default(now())
  
  @@index([cotistaId])
  @@index([lida])
  @@index([createdAt])
  @@map("notificacoes")
}
